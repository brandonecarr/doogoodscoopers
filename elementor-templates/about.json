            {
              "id": "00000017",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div style=\"display:flex;gap:24px;font-family:Montserrat,sans-serif;\">\n        \n          <div style=\"text-align:center;\">\n            <div style=\"font-size:24px;font-weight:800;color:#5ab3a9;\">2024</div>\n            <div style=\"font-size:12px;color:#4b5563;margin-top:2px;\">Founded</div>\n          </div>\n          <div style=\"text-align:center;\">\n            <div style=\"font-size:24px;font-weight:800;color:#5ab3a9;\">521+</div>\n            <div style=\"font-size:12px;color:#4b5563;margin-top:2px;\">Families Served</div>\n          </div>\n          <div style=\"text-align:center;\">\n            <div style=\"font-size:24px;font-weight:800;color:#5ab3a9;\">5.0★</div>\n            <div style=\"font-size:12px;color:#4b5563;margin-top:2px;\">Google Rating</div>\n          </div>\n      </div>"
