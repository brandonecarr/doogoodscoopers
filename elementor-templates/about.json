            },
            {
              "id": "00000013",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"color:#4b5563;text-align:left;line-height:1.85;\">DooGoodScoopers was founded in 2024 by Brandon and Valerie — a husband-and-wife team from the Inland Empire who were tired of seeing neighbors struggle with one of the most dreaded yard chores.</p>",
                "align": "left"
              }
            },
            {
              "id": "00000014",
              "elType": "widget",
              "widgetType": "spacer",
              "settings": {
                "space": {
                  "unit": "px",
                  "size": 8
                }
              }
            },
            {
              "id": "00000015",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"color:#4b5563;text-align:left;line-height:1.85;\">We started small in Rancho Cucamonga. Within months, word spread across the region. Today we proudly serve 90+ ZIP codes across San Bernardino and Los Angeles counties.</p>",
                "align": "left"
              }
            },
            {
              "id": "00000016",
              "elType": "widget",
              "widgetType": "spacer",
              "settings": {
                "space": {
                  "unit": "px",
                  "size": 14
