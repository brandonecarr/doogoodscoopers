            {
              "id": "00000011",
              "elType": "widget",
              "widgetType": "accordion",
              "settings": {
                "tabs": [
                  {
                    "_id": "00000009",
                    "tab_title": "Do you service the entire yard?",
                    "tab_content": "We clean the entire yard — front, back, and side areas. On your first service we'll walk through to identify access points and specific areas."
                  },
                  {
                    "_id": "0000000a",
                    "tab_title": "Do you provide service year-round?",
                    "tab_content": "Yes — 52 weeks a year, rain or shine. In rare cases of extreme weather we'll reschedule and always notify you in advance."
                  },
                  {
                    "_id": "0000000b",
                    "tab_title": "How is pricing determined?",
                    "tab_content": "Pricing is based on the number of dogs and frequency (weekly, bi-weekly, or one-time). Get an instant quote online in under 2 minutes."
                  },
                  {
                    "_id": "0000000c",
                    "tab_title": "Is there a contract?",
                    "tab_content": "No contracts — ever. Pause or cancel anytime through your customer portal. We earn your business every single visit."
                  },
                  {
                    "_id": "0000000d",
                    "tab_title": "What do you do with the waste?",
                    "tab_content": "All waste is double-bagged and removed from your property following local waste management guidelines. Never left at your home."
                  },
                  {
                    "_id": "0000000e",
                    "tab_title": "Do my dogs need to be inside?",
                    "tab_content": "For safety, we ask dogs to be secured indoors or in a separate area. We'll send an ETA text before arriving."
                  },
                  {
                    "_id": "0000000f",
                    "tab_title": "How do I know when you're coming?",
                    "tab_content": "You'll receive SMS when your tech is on the way and when service is complete. View upcoming dates in your customer portal."
                  },
                  {
                    "_id": "00000010",
                    "tab_title": "What if I'm not satisfied?",
                    "tab_content": "100% satisfaction guarantee. Let us know within 24 hours and we'll return to redo the service at no charge — no questions asked."
                  }
                ],
                "title_html_tag": "h3",
                "active_item": 1
              }
